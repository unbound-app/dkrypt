{
  "name": "dkrypt-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "bun --watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "paddle:seed": "bun scripts/seed-paddle-catalog.ts",
    "paddle:webhook": "bun scripts/configure-paddle-webhook.ts",
    "build:web": "cd web && bun install --frozen-lockfile && bun run build",
    "typecheck:web": "cd web && bun install --frozen-lockfile && bun run typecheck"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.3",
    "@paddle/paddle-node-sdk": "^3.8.0",
    "adm-zip": "^0.6.0",
    "bplist-parser": "^0.3.2",
    "cron-parser": "^5",
    "discord-api-types": "^0.38.50",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "plist": "^5.0.0",
    "ssh2": "^1.17.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "@types/ssh2": "^1.15.5",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.2"
  }
}
